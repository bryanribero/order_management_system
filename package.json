{
  "name": "order_management_system",
  "version": "1.0.0",
  "description": "Un sistema gestor de pedidos, el cual un dueño va a poder almacenar productos, clientes y getionar los pedidos de esos clientes por estado",
  "scripts": {
    "dev": "nodemon server.js",
    "test": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "start": "cross-env NODE_ENV=prod node server.js",
    "release": "bumpp --commit --push --tag",
    "migration-create": "sequelize-cli migration:create --name",
    "migrate-dev": "cross-env NODE_ENV=dev sequelize-cli db:migrate --env development",
    "undo-migrate-dev": "cross-env NODE_ENV=dev sequelize-cli db:migrate:undo --env development",
    "all-undo-migrate-dev": "cross-env NODE_ENV=dev sequelize-cli db:migrate:undo:all --env development",
    "migrate-test": "cross-env NODE_ENV=test sequelize-cli db:migrate --env test",
    "undo-migrate-test": "cross-env NODE_ENV=test sequelize-cli db:migrate:undo --env test",
    "all-undo-migrate-test": "cross-env NODE_ENV=test sequelize-cli db:migrate:undo:all --env test",
    "migrate-prod": "cross-env NODE_ENV=prod sequelize-cli db:migrate --env production",
    "undo-migrate-prod": "cross-env NODE_ENV=prod sequelize-cli db:migrate:undo --env production",
    "all-undo-migrate-prod": "cross-env NODE_ENV=prod sequelize-cli db:migrate:undo:all --env production"
  },
  "keywords": [],
  "type": "module",
  "author": "Bryan Ribero",
  "license": "ISC",
  "packageManager": "pnpm@10.33.3",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "bumpp": "^11.1.0",
    "cross-env": "^10.1.0",
    "eslint": "10.3.0",
    "globals": "^17.6.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "prettier": "3.8.3",
    "supertest": "^7.2.2"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dompurify": "^3.4.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.0",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsdom": "^29.1.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.5",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.9.0"
  }
}
